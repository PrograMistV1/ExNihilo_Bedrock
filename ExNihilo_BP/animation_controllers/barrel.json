{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.barrel": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "wooden_barrel_empty": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_empty')"
                        },
                        {
                            "wooden_barrel_0": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_0')"
                        },
						{
                            "wooden_barrel_1": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_1')"
                        },
                        {
                            "wooden_barrel_2": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_2')"
                        },
						{
                            "wooden_barrel_3": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_3')"
                        },
                        {
                            "wooden_barrel_back": "!query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'wooden_barrel_0')"
                        },
                        {
                            "stone_barrel_empty": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_empty')"
                        },
                        {
                            "stone_barrel_0": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_0')"
                        },
						{
                            "stone_barrel_1": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_1')"
                        },
                        {
                            "stone_barrel_2": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_2')"
                        },
						{
                            "stone_barrel_3": "query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_3')"
                        },
                        {
                            "stone_barrel_back": "!query.is_in_water_or_rain && query.relative_block_has_any_tag(0,0,0,'stone_barrel_0')"
                        }
                    ]
                },
                "wooden_barrel_empty": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel_0",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "wooden_barrel_0": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel_1",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
				"wooden_barrel_1": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel_2",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "wooden_barrel_2": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel_3",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
				"wooden_barrel_3": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel_4",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "wooden_barrel_back": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:wooden_barrel",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "stone_barrel_empty": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel_0",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "stone_barrel_0": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel_1",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
				"stone_barrel_1": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel_2",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "stone_barrel_2": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel_3",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
				"stone_barrel_3": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel_4",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                },
                "stone_barrel_back": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/setblock ~~~ sf:stone_barrel",
                        "/execute @s ~~~ event entity @s despawn_event"
                    ]
                }
            }
        }
    }
}