{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.crucible": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "crucible_full": "query.relative_block_has_any_tag(0,0,0,'crucible_full')"
                        },
                        {
                            "crucible_0": "query.relative_block_has_any_tag(0,0,0,'crucible_0')"
                        },
                        {
                            "crucible_1": "query.relative_block_has_any_tag(0,0,0,'crucible_1')"
                        },
                        {
                            "crucible_2": "query.relative_block_has_any_tag(0,0,0,'crucible_2')"
                        },
                        {
                            "crucible_3": "query.relative_block_has_any_tag(0,0,0,'crucible_3')"
                        },
                        {
                            "crucible_4": "query.relative_block_has_any_tag(0,0,0,'crucible_4')"
                        }
                    ]
                },
                "crucible_full": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/execute @s ~~~ detect ~~-1~ fire 0 setblock ~~~ sf:crucible_0",
                        "/execute @s ~~~ detect ~~-1~ lava 0 setblock ~~~ sf:crucible_0",
