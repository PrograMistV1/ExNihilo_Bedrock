{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.copper_sand": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "debag": "query.is_on_ground"
                        },
                        {
                            "falling": "(1.0)"
                        }
                    ]
                },
                "debag": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/execute @s ~~~ function falling_blocks/copper_sand_break"
                    ]
                },
                "falling": {
                    "transitions": [
                        {
                            "default": "(1.0)"
                        }
                    ],
                    "on_entry": [
                        "/function falling_blocks/copper_sand_falling"
                    ]
                }
            }
        }
    }
}