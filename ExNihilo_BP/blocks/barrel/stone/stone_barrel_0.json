{
    "format_version": "1.18",
    "minecraft:block": {
        "description": {
            "identifier": "sf:stone_barrel_0",
			"properties": {
				"sf:event": [ false, true ]
			}
        },
		"components": {
        	"minecraft:geometry": "geometry.addon_barrel",
			"minecraft:material_instances": {
				"*": {
					"texture": "stone_barrel",
					"render_method": "alpha_test"
				}
			},
			"minecraft:block_light_filter": 2,
			"minecraft:destroy_time": 2.0,
           	"minecraft:aim_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:block_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:ticking": {
				"looping": false,
				"on_tick": {
					"event": "event"
				},
				"range": [10, 10]
			},
			"minecraft:loot": "loot_tables/barrel/stone_barrel.json"
        },
		"events":{
			"event": {
				"sequence": [
					{
						"condition": "q.block_property('sf:event') == false",
						"set_block_property": {
							"sf:event": true
						},
						"run_command": {
							"command": "summon sf:barrel ~~-0.5~",
							"target" : "self"
						}
					}
				]
			}
		},
		"permutations": [
			{	
				"condition": "q.block_property('sf:event') == true",
				"components": {
					"tag:stone_barrel_0": {}
				}
			}
		]
	}
}