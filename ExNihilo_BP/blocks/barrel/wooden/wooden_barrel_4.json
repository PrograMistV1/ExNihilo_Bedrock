{
    "format_version": "1.18",
    "minecraft:block": {
        "description": {
            "identifier": "sf:wooden_barrel_4",
			"properties": {
				"sf:type": [ 0, 1 ],
				"sf:effects": [ 0, 1 ]
			}
        },
		"components": {
        	"minecraft:geometry": "geometry.addon_barrel_4",
			"minecraft:material_instances": {
				"*": {
					"texture": "wooden_barrel",
					"render_method": "blend"
				},
				"barrel": {
					"texture": "wooden_barrel",
					"render_method": "opaque"
				},
				"inside": {
					"texture": "water",
					"render_method": "blend"
				}
			},
			"minecraft:on_interact": { 
				"event": "tap",
				"target": "self"
			},
			"minecraft:block_light_filter": 2,
			"minecraft:destroy_time": 2.0,
           	"minecraft:aim_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:block_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:on_player_destroyed": {
				"event": "destroy"
			},
			"minecraft:loot": "loot_tables/barrel/wooden_barrel.json"
        },
		"events": {
			"destroy": {
				"sequence": [
					{
						"condition": "q.block_property('sf:type') == 1",
						"spawn_loot": {
							"table": "loot_tables/barrel/clay.json"
						}
					}
				]
			},
			"effects": {
				"sequence": [
					{
						"condition": "q.block_property('sf:effects') == 1",
						"run_command": {
							"command": [
								"playsound bucket.empty_water @a ~~~",
								"setblock ~~~ sf:wooden_barrel"
							],
							"target" : "self"
						}
					}
				]
			},	
			"tap": {
				"sequence": [
					{
						"condition": "q.block_property('sf:type') == 0 && query.get_equipped_item_name == 'bucket'",
						"decrement_stack": {},
						"run_command": {
							"command": "give @s water_bucket",
							"target" : "player"
						},
						"set_block_property": {
							"sf:effects": 1
						}
					},
					{
						"condition": "q.block_property('sf:type') == 0 && query.get_equipped_item_name == 'dust'",
						"decrement_stack": {},
						"set_block_property": {
							"sf:type": 1
						}
					},
					{
						"condition": "q.block_property('sf:type') == 0 && query.get_equipped_item_name == 'spores'",
						"decrement_stack": {},
						"run_command": {
							"command": "setblock ~~~ sf:wooden_barrel_witch_water",
							"target" : "self"
						}
					},
					{
						"condition": "q.block_property('sf:type') == 1",
						"run_command": {
							"command": [
								"structure load clay ~~1~",
								"setblock ~~~ sf:wooden_barrel"
							],
							"target" : "self"
						}
					}
				] 
			}
		},
		"permutations": [
			{
				"condition": "q.block_property('sf:effects') == 1",
				"components": {
					"minecraft:ticking": {
						"looping": false,
						"on_tick": {
							"event": "effects"
						},
						"range": [0, 0]
					}
				}
			},
			{
				"condition": "q.block_property('sf:type') == 1",
				"components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "wooden_barrel",
							"render_method": "alpha_test"
						},
						"inside": {
							"texture": "clay",
							"render_method": "alpha_test"
						}
					}
				}
			}
		]
	}
}