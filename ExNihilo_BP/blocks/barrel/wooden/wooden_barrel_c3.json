{
	"format_version": "1.18.0",
	"minecraft:block": {
		"description": {
			"identifier": "sf:wooden_barrel_c3",
			"properties": {
				"sf:type": [ 0, 1 ],
				"sf:compost": [ 0, 1, 2, 3, 4 ]
			}
		},
		"components": {
			"minecraft:geometry": "geometry.addon_barrel_3",
			"minecraft:material_instances": {
				"*": {
					"texture": "wooden_barrel",
					"render_method": "alpha_test"
				},
				"inside": {
					"texture": "leaves_0",
					"render_method": "alpha_test"
				}
			},
			"minecraft:block_light_filter": 2,
			"minecraft:destroy_time": 2.0,
			"minecraft:aim_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:block_collision": {
				"origin": [-7.0, 0.0, -7.0],
				"size": [14,16,14]
			},
			"minecraft:on_interact": { 
			"event": "tap",
			"target": "self"
			},
			"minecraft:loot": "loot_tables/barrel/wooden_barrel.json"
		},
		"events": {
			"composting": {
				"run_command": {
					"command": "setblock ~~~ sf:wooden_barrel_c4",
					"target" : "self"
				}
			},
			"tap": {
				"sequence": [
					{
						"condition": "(q.block_property('sf:type') == 0 || q.block_property('sf:type') == 1) && q.block_property('sf:compost') < 4 && (query.get_equipped_item_name == 'sapling' || query.get_equipped_item_name == 'cactus' || query.get_equipped_item_name == 'melon_block' || query.get_equipped_item_name == 'pumpkin')",
						"decrement_stack": {},
						"set_block_property": {
							"sf:type": 1,
							"sf:compost": "q.block_property('sf:compost') + 2"
						}
					},
					{
						"condition": "(q.block_property('sf:type') == 0 || q.block_property('sf:type') == 1) && q.block_property('sf:compost') < 4 && (query.get_equipped_item_name == 'leaves' || query.get_equipped_item_name == 'leaves2' || query.get_equipped_item_name == 'silkworm' || query.get_equipped_item_name == 'beetroot_seeds' || query.get_equipped_item_name == 'melon_seeds' || query.get_equipped_item_name == 'pumpkin_seeds' || query.get_equipped_item_name == 'wheat_seeds' || query.get_equipped_item_name == 'potato' || query.get_equipped_item_name == 'carrot' || query.get_equipped_item_name == 'beetroot' || query.get_equipped_item_name == 'apple' || query.get_equipped_item_name == 'sawdust')",
						"decrement_stack": {},
						"set_block_property": {
							"sf:type": 1,
							"sf:compost": "q.block_property('sf:compost') + 1"
						}
					}
				] 
			}
		},
		"permutations": [
			{
				"condition": "q.block_property('sf:type') == 1",
				"components": {
					"minecraft:geometry": "geometry.addon_barrel_3",
					"minecraft:material_instances": {
						"*": {
							"texture": "wooden_barrel",
							"render_method": "alpha_test"
						},
						"inside": {
							"texture": "leaves_0",
							"render_method": "alpha_test"
						}
					}
				}
			},
			{
				"condition": "q.block_property('sf:compost') >= 4",
				"components": {
					"minecraft:ticking": {
						"looping": false,
						"on_tick": {
							"event": "composting"
						},
						"range": [0, 0]
					}
				}
			}
		]
	 }
 }