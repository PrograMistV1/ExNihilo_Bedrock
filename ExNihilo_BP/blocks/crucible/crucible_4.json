{
    "format_version": "1.18.0",
    "minecraft:block": {
        "description": {
            "identifier": "sf:crucible_4",
			"properties": {
				"sf:event": [ false, true ]
			}
        },
        "components": {
            "minecraft:material_instances": {
				"*": {
					"texture": "crucible_cobblestone",
					"render_method": "alpha_test"
				}
			},
            "minecraft:geometry": "geometry.crucible_4",
			"minecraft:ticking": {
				"looping": false,
				"on_tick": {
					"event": "event"
				},
				"range": [10, 10]
			},
			"minecraft:block_light_filter": 2,
			"minecraft:destroy_time": 3.0,
			"minecraft:loot": "loot_tables/crudible.json"
        },
		"events":{
			"event": {
				"sequence": [
					{
						"condition": "q.block_property('sf:event') == false",
						"set_block_property": {
							"sf:event": true
						},
						"run_command": {
							"command": "summon sf:crucible ~~-0.5~",
							"target" : "self"
						}
					}
				]
			}
		},
		"permutations": [
			{	
				"condition": "q.block_property('sf:event') == true",
				"components": {
					"tag:crucible_4": {}
				}
			}
		]
	}
}