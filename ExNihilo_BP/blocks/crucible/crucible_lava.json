{
    "format_version": "1.18.0",
    "minecraft:block": {
        "description": {
            "identifier": "sf:crucible_lava",
			"properties": {
				"sf:use": [ false, true ]
			}
        },
        "components": {
            "minecraft:material_instances": {
				"*": {
					"texture": "crucible_lava",
					"render_method": "alpha_test"
				}
			},
            "minecraft:geometry": "geometry.crucible_4",
			"minecraft:on_interact": { 
                "event": "tap",
                "target": "self"
			},
			"minecraft:destroy_time": 3.0,
			"minecraft:block_light_filter": 2,
			"minecraft:loot": "loot_tables/crudible.json"
        },
		"events":{
			"use": {
				"run_command": {
					"command": "setblock ~~~ sf:crucible",
					"target" : "self"
				}
			},
			"tap": {
				"sequence": [
					{
						"condition": "query.get_equipped_item_name == 'bucket'",
						"decrement_stack": {},
						"run_command": {
							"command": "give @s lava_bucket",
							"target" : "player"
						},
						"set_block_property": {
							"sf:use": true
						}
					}
				]
			}
		},
		"permutations": [
			{	
				"condition": "q.block_property('sf:use') == true",
				"components": {
					"minecraft:ticking": {
						"looping": true,
						"on_tick": {
							"event": "use"
						},
						"range": [0, 0]
					}
				}
			}
		]
	}
}