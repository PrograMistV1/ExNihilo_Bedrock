{
    "format_version": "1.18.0",
    "minecraft:block": {
        "description": {
            "identifier": "sf:acacia_leaves",
            "properties": {
				"sf:infected": [ false, true ]
			}
        },
        "components": {
			"minecraft:material_instances": {
				"*": {
					"texture": "infecting_acacia_leaves",
					"render_method": "alpha_test"
				}
			},
            "minecraft:ticking": {
				"looping": false,
				"on_tick": {
					"event": "infected"
				},
				"range": [25, 35]
			},
            "minecraft:on_player_destroyed":{
                "condition": "(query.get_equipped_item_name == 'wooden_crook' || query.get_equipped_item_name == 'bone_crook' || query.get_equipped_item_name == 'iron_crook') && q.block_property('sf:infected') == true",
                "event" : "loot",
                "target": "self"
            },
            "minecraft:destroy_time": 1,
            "minecraft:unit_cube": {},
			"minecraft:block_light_filter": 2,
            "minecraft:loot": "empty"
            
        },
        "events":{
            "loot": {
                "spawn_loot": {
                    "table": "loot_tables/infected_leaves.json"
                }
            },
            "infected": {
                "set_block_property": {
                    "sf:infected": true
                },
                "run_command": {
                    "command": "function infected",
                    "target" : "self"
                }
            }
        },
        "permutations": [
			{
				"condition": "q.block_property('sf:infected') == true",
				"components": {
					"minecraft:material_instances": {
                        "*": {
                            "texture": "infected_acacia_leaves",
                            "render_method": "alpha_test"
                        }
                    }
				}
			}
        ]
    }
}