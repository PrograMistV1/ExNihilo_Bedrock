
{
    "format_version": "1.18.0",
    "minecraft:block": {
        "description": {
            "identifier": "sf:sieve",
			"properties": {
                "sf:tap": [ 0, 1, 2, 3, 4 ],
				"sf:type": [ 0, 1, 2, 3, 4, 5 ]
			}
        },
        "components": {
			"minecraft:destroy_time": 2.5,
			"minecraft:geometry": "geometry.sieve_empty",
			"minecraft:block_light_filter": 0,
            "minecraft:creative_category": {
	            "category": "nature"
			},
			"minecraft:display_name":  "Sieve",
			"minecraft:aim_collision":{
				"origin": [-8.0, 0.0, -8.0],
				"size": [16,15,16]
			},
			"minecraft:block_collision":{
				"origin": [-8.0, 0.0, -8.0],
				"size": [16,15,16]
			},
			"minecraft:on_interact": { 
                "event": "tap",
                "target": "self"
			}
        },
		"events": {
			"tap":{
				"sequence":[
					{
						"condition": "q.block_property('sf:tap') >= 1 && q.block_property('sf:tap') <= 4 ",
						"run_command": {
							"command": [
							"playsound dig.sand @a ~~~",
							"particle minecraft:llama_spit_smoke ~~1~"
							],
							"target" : "self"
						}
					},
					{
						"condition": "query.get_equipped_item_name == 'dirt' && q.block_property('sf:type') == 0 ",
						"set_block_property": {
							"sf:type": 1,
							"sf:tap": 1
						},
						"decrement_stack": {}
					},
					{
						"condition": "query.get_equipped_item_name == 'gravel' && q.block_property('sf:type') == 0 ",
						"set_block_property": {
							"sf:type": 2,
							"sf:tap": 1
						},
						"decrement_stack": {}
					},
					{
						"condition": "query.get_equipped_item_name == 'sand' && q.block_property('sf:type') == 0 ",
						"set_block_property": {
							"sf:type": 3,
							"sf:tap": 1
						},
						"decrement_stack": {}
					},
					{
						"condition": "query.get_equipped_item_name == 'dust' && q.block_property('sf:type') == 0 ",
						"set_block_property": {
							"sf:type": 4,
							"sf:tap": 1
						},
						"decrement_stack": {}
					},
					{
						"condition": "query.get_equipped_item_name == 'soul_sand' && q.block_property('sf:type') == 0 ",
						"set_block_property": {
							"sf:type": 5,
							"sf:tap": 1
						},
						"decrement_stack": {}
					},
					{
						"condition": "q.block_property('sf:tap') >= 1 && q.block_property('sf:tap') < 4 ",
						"set_block_property": {
							"sf:tap": "q.block_property('sf:tap') + 1 "
						}
					},
					{
						"condition": "q.block_property('sf:tap') == 4 && q.block_property('sf:type') == 1 ",
						"set_block_property": {
							"sf:type": 0,
							"sf:tap": 0
						},
						"run_command": {
							"command": [
							"setblock ~~~ sf:sieve_loot_dirt",
							"tp @e[type=item,r=0.5] ~ ~0.5 ~"
							],
							"target" : "self"
						}
					},
					{
						"condition": "q.block_property('sf:tap') == 4 && q.block_property('sf:type') == 2 ",
						"set_block_property": {
							"sf:type": 0,
							"sf:tap": 0
						},
						"run_command": {
							"command": [
							"setblock ~~~ sf:sieve_loot_gravel",
							"tp @e[type=item,r=0.4] ~ ~0.5 ~"
							],
							"target" : "self"
						}
					},
					{
						"condition": "q.block_property('sf:tap') == 4 && q.block_property('sf:type') == 3 ",
						"set_block_property": {
							"sf:type": 0,
							"sf:tap": 0
						},
						"run_command": {
							"command": [
							"setblock ~~~ sf:sieve_loot_sand",
							"tp @e[type=item,r=0.4] ~ ~0.5 ~"
							],
							"target" : "self"
						}
					},
					{
						"condition": "q.block_property('sf:tap') == 4 && q.block_property('sf:type') == 4 ",
						"set_block_property": {
							"sf:type": 0,
							"sf:tap": 0
						},
						"run_command": {
							"command": [
							"setblock ~~~ sf:sieve_loot_dust",
							"tp @e[type=item,r=0.4] ~ ~0.5 ~"
							],
							"target" : "self"
						}
					},
					{
						"condition": "q.block_property('sf:tap') == 4 && q.block_property('sf:type') == 5 ",
						"set_block_property": {
							"sf:type": 0,
							"sf:tap": 0
						},
						"run_command": {
							"command": [
							"setblock ~~~ sf:sieve_loot_soul_sand",
							"tp @e[type=item,r=0.4] ~ ~0.5 ~"
							],
							"target" : "self"
						}
					}
				]
			}
        },
		"permutations": [
            {
                "condition": "q.block_property('sf:type') == 0 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_0",
							"render_method": "alpha_test"
						}
					}
                }
            },
			{
                "condition": "q.block_property('sf:type') == 1 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_1",
							"render_method": "alpha_test"
						}
					}
                }
            },
			{
                "condition": "q.block_property('sf:type') == 2 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_2",
							"render_method": "alpha_test"
						}
					}
                }
            },
			{
                "condition": "q.block_property('sf:type') == 3 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_3",
							"render_method": "alpha_test"
						}
					}
                }
            },
			{
                "condition": "q.block_property('sf:type') == 4 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_4",
							"render_method": "alpha_test"
						}
					}
                }
            },
			{
                "condition": "q.block_property('sf:type') == 5 ",
                "components": {
					"minecraft:material_instances": {
						"*": {
							"texture": "sieve_5",
							"render_method": "alpha_test"
						}
					}
                }
            },{
                "condition": "q.block_property('sf:tap') == 0 ",
                "components": {
					"minecraft:geometry": "geometry.sieve_empty"
                }
            },
			{
                "condition": "q.block_property('sf:tap') == 1 ",
                "components": {
					"minecraft:geometry": "geometry.sieve_1"
                }
            },
			{
                "condition": "q.block_property('sf:tap') == 2 ",
                "components": {
					"minecraft:geometry": "geometry.sieve_2"
                }
            },
			{
                "condition": "q.block_property('sf:tap') == 3 ",
                "components": {
					"minecraft:geometry": "geometry.sieve_3"
                }
            },
			{
                "condition": "q.block_property('sf:tap') == 4 ",
                "components": {
					"minecraft:geometry": "geometry.sieve_4"
                }
            }
		]
    }
}