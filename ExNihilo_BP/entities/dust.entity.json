{
	"format_version": "1.21.50",
	"minecraft:entity": {
		"description": {
			"identifier": "exnihilo:dust.entity",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"falling_block:cooldown": {
				"minecraft:timer": {
					"looping": false, "time": 0.15, "time_down_event": {"event": "falling_block:is_on_ground"}
				}
			}
		},
		"components": {
			"minecraft:collision_box": {"width": 0.0, "height": 0.0},
			"minecraft:is_stackable": {},
			"minecraft:pushable": {"is_pushable": false, "is_pushable_by_piston": true},
			"minecraft:physics": {"has_collision": true, "has_gravity": true},
			"minecraft:damage_sensor": {
				"triggers": {"cause": "all", "deals_damage": "no"}
			},
			"minecraft:health": {"value": 1, "max": 1},
			"minecraft:transient": {},
			"minecraft:environment_sensor": {
				"triggers": {
					"filters": {"test": "on_ground", "value": true},
					"event": "falling_block:start_cooldown"
				}
			}
		},
		"events": {
			"falling_block:start_cooldown": {
				"filters": {"test": "has_component", "operator": "not", "value": "minecraft:timer"},
				"add": {"component_groups": ["falling_block:cooldown"]}
			},
			"falling_block:is_on_ground": {
				"queue_command": {"command": "scriptevent falling_block:is_on_ground"}
			}
		}
	}
}
